// config.h.example — copy this file to config.h and fill in your values
// config.h is gitignored and must never be committed

#pragma once

// WiFi
#define WIFI_SSID     "your-wifi-name"
#define WIFI_PASSWORD "your-wifi-password"

// Firebase
#define FIREBASE_API_KEY    "your-firebase-api-key"
#define FIREBASE_PROJECT_ID "percipio-base"

// Telegram
#define TELEGRAM_BOT_TOKEN "your-bot-token"
#define TELEGRAM_CHAT_ID   "your-chat-id"

// RFID card mapping — fill in after first scan (read UID from Serial Monitor)
// Format: { "UID_HEX", "Name" }
// static const char* CARD_MAP[][2] = {
//   { "A1B2C3D4", "Mike" },
//   { "E5F6G7H8", "Jacek" },
// };
// static const int CARD_COUNT = 2;

// GPIO pin assignments — see WIRING.md for full wiring diagram
#define PIN_LED_GREEN   25
#define PIN_LED_RED     32
#define PIN_LED_BLUE    33

#define PIN_RADAR_RX    13   // LD2450 TX → ESP32
#define PIN_RADAR_TX    17   // ESP32 → LD2450 RX

#define PIN_RFID_MISO   2
#define PIN_RFID_CS     27
#define PIN_RFID_RST    26
